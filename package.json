{
  "name": "lotion",
  "version": "1.0.0",
  "description": "AI Life Coach - Your AI-powered life coach for goals, calendar, and clarity",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "npx @opennextjs/cloudflare build",
    "preview:cloudflare": "npx @opennextjs/cloudflare preview",
    "deploy:cloudflare": "npx @opennextjs/cloudflare deploy",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- npx tsx src/db/seed.ts",
    "db:reset": "drizzle-kit drop && drizzle-kit migrate && dotenv -e .env.local -- npx tsx src/db/seed.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "life-coach",
    "goals",
    "calendar",
    "productivity",
    "next.js"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1007.0",
    "@neondatabase/serverless": "^1.1.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.80.7",
    "@tiptap/extension-character-count": "^3.26.0",
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-task-item": "^3.26.0",
    "@tiptap/extension-task-list": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.1",
    "next": "^15.5.19",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "sonner": "^1.7.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.1.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.0.0",
    "msw": "^2.7.5",
    "postgres": "^3.4.9",
    "prettier": "^3.0.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
