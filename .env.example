# =============================================================================
# Lotion — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (Neon Postgres)
# -----------------------------------------------------------------------------
# Connection string for your Neon (or any Postgres) database.
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
#
# Get yours at: https://neon.tech → New Project → Connection String
DATABASE_URL=


# -----------------------------------------------------------------------------
# AWS Bedrock (AI / Claude)
# -----------------------------------------------------------------------------
# Lotion uses AWS Bedrock to call Claude models — NOT the direct Anthropic API.
# You need an AWS account with Bedrock model access enabled in the chosen region.
#
# Setup:
#   1. Create an IAM user with the AmazonBedrockFullAccess (or scoped) policy.
#   2. Generate an access key pair for that user.
#   3. Enable model access for Claude in the Bedrock console for your region:
#      https://console.aws.amazon.com/bedrock/home#/modelaccess
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# -----------------------------------------------------------------------------
# Supabase (Authentication)
# -----------------------------------------------------------------------------
# Lotion uses Supabase for user auth (sign-up, sign-in, session management).
#
# Get these values from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role key — only needed for server-side admin operations
# (e.g. creating users programmatically, bypassing RLS). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# Google Calendar OAuth
# -----------------------------------------------------------------------------
# Required for Google Calendar sync (read/write events).
#
# Setup:
#   1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (Web application)
#   3. Add the redirect URI below to "Authorised redirect URIs"
#   4. Enable the Google Calendar API for your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback


# -----------------------------------------------------------------------------
# Microsoft Outlook Calendar OAuth (optional — future)
# -----------------------------------------------------------------------------
# Uncomment when Outlook sync is implemented.
# Register your app at: https://portal.azure.com → App registrations
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# OUTLOOK_REDIRECT_URI=http://localhost:3000/api/calendar/outlook/callback
# OUTLOOK_TENANT_ID=common


# -----------------------------------------------------------------------------
# App (optional)
# -----------------------------------------------------------------------------
# Public URL of the app — used for generating absolute URLs (e.g. OAuth callbacks,
# email links). Defaults to http://localhost:3000 in development.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
